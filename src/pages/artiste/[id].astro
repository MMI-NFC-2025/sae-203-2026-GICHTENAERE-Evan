---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/hero.astro';
import { allArtistes, getArtisteByIdWithScene } from '../../../backend/backend.mjs';

export async function getStaticPaths() {
  const artistes = await allArtistes();
  return artistes.map((artiste: any) => ({
    params: { id: artiste.id },
  }));
}

const { id } = Astro.params;
const artiste = await getArtisteByIdWithScene(id);
const pbUrl = 'https://sae203.lesrivesduterritoire.evangichtenaere.fr:443';
const photoUrl = `${pbUrl}/api/files/artiste/${artiste.id}/${artiste.photo_artiste}`;
const sceneName = artiste.expand?.scene?.nom_scene ?? 'Scène inconnue';

const dateObj = new Date(artiste.date_representation);
const months = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
const jourPassage = `${dateObj.getDate()} ${months[dateObj.getMonth()]}`;

const galerieImages: string[] = artiste.galerie_artiste ?? [];
---

<Layout>
  <Hero title="Les rives du territoire" subTitle={artiste.nom_artiste} />

  <div class="px-[15px] mt-5 lg:max-w-2xl lg:mx-auto lg:w-full">

    <!-- Photo de l'artiste -->
    <div class="w-full rounded-[15px] overflow-hidden border border-[#058CD8]">
      <img
        src={photoUrl}
        alt={artiste.nom_artiste}
        class="w-full h-auto object-cover"
      />
    </div>

    <!-- Description -->
    <p class="font-poppins text-sm leading-relaxed mt-5 italic">{artiste.description_artiste}</p>

    <!-- Horaires -->
    <h2 class="font-inder mt-5">Horaires</h2>

    <div class="mt-5 flex flex-col gap-2 font-poppins">
      <p><span class="font-bold">Jour de passage :</span> {jourPassage}</p>
      <p><span class="font-bold">Heure de passage :</span> {artiste.heure}</p>
      <p><span class="font-bold">Scène utilisée :</span> {sceneName}</p>
    </div>

    <!-- Galerie -->
    {galerieImages.length > 0 && (
      <h2 class="font-inder mt-5">Galerie</h2>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 mt-5">
        {galerieImages.map((img: string) => (
          <div class="rounded-[10px] overflow-hidden">
            <img
              src={`${pbUrl}/api/files/artiste/${artiste.id}/${img}`}
              alt={`${artiste.nom_artiste} galerie`}
              class="w-full h-40 object-cover"
            />
          </div>
        ))}
      </div>
    )}

    <div class="mb-5"></div>

  </div>
</Layout>