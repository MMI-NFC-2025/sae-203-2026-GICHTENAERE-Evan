---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero.astro";
import Button from "../components/button.astro";
import Polygon from "../assets/Polygon_informations.svg";

const faqs = [
  {
    question: "Est-ce que le festival est accessible aux personnes à mobilité réduite (PMR) ?",
    answer: "Oui, le site des Berges de la Savoureuse est aménagé avec des cheminements accessibles, des zones réservées près des scènes et des sanitaires adaptés pour les personnes à mobilité réduite. Un accueil spécifique sera indiqué à l'entrée pour accompagner si besoin.",
  },
  {
    question: "Est-ce qu'il y aura de la restauration sur place ?",
    answer: "Oui, plusieurs stands de restauration et foodtrucks seront présents sur le site, avec des options végétariennes, véganes et locales. Des points de bar proposeront également boissons chaudes, softs et boissons sans alcool.",
  },
  {
    question: "Puis-je entrer avec mon propre sac et une bouteille d'eau ?",
    answer: "Les sacs sont autorisés mais feront l'objet d'un contrôle à l'entrée pour des raisons de sécurité. Les bouteilles d'eau en plastique souple et sans bouchon sont acceptées, et des points d'eau seront disponibles pour les remplir sur le site.",
  },
];
---

<Layout>
     <Hero title="Les rives du territoire" subTitle="Informations" /> 
     <h2 class="font-inder px-[15px] mt-5 lg:max-w-2xl lg:mx-auto">Tarifs</h2>
     <p class="font-[Poppins,sans-serif] px-[15px] mt-5 lg:max-w-2xl lg:mx-auto">Les Rives du Territoire propose plusieurs formules de billets pour s’adapter à tous les publics. Vous pourrez choisir entre un billet jour (accès à une journée de concerts) et un pass 4 jours pour profiter de l’ensemble du festival. Des tarifs réduits seront disponibles pour les étudiants, les moins de 18 ans et les demandeurs d’emploi, sur présentation d’un justificatif au moment du contrôle des billets.</p>
     <div class="flex justify-center mt-5 lg:max-w-2xl lg:mx-auto">
       <Button text="Accéder à la billetterie" />
     </div>
     <h2 class="font-inder px-[15px] mt-5 lg:max-w-2xl lg:mx-auto">Hébergements</h2>
     <p class="font-[Poppins,sans-serif] px-[15px] mt-5 lg:max-w-2xl lg:mx-auto">Pour prolonger l’expérience du festival, de nombreux hébergements sont accessibles autour de Belfort : hôtels en centre-ville, chambres d’hôtes, campings et locations de vacances. Que vous soyez plutôt confort, économique ou proche de la nature, vous trouverez une solution adaptée à votre budget et à la durée de votre séjour. Il est conseillé de réserver en avance, les disponibilités pouvant être limitées pendant la période du festival.</p>
     <h2 class="font-inder px-[15px] mt-5 lg:max-w-2xl lg:mx-auto">Transport</h2>
     <p class="font-[Poppins,sans-serif] px-[15px] mt-5 lg:max-w-2xl lg:mx-auto">Le festival est facilement accessible en train, en bus, en voiture ou en covoiturage. Depuis la gare de Belfort, des lignes de bus permettent de rejoindre rapidement le centre-ville et les Berges de la Savoureuse. En voiture, des parkings et aires de covoiturage sont situés aux abords de la ville, il est recommandé de privilégier le partage de trajets et les transports en commun pour réduire l’impact environnemental et fluidifier l’accès au site.</p>
    <h2 class="font-inder px-[15px] mt-5 lg:max-w-2xl lg:mx-auto">FAQ</h2>

    <div class="px-[15px] mt-5 flex flex-col gap-[1.25rem] max-w-2xl mx-auto w-full">
      {faqs.map((faq, i) => (
        <div class="faq-item">
          <button
            class="faq-btn w-full flex items-center justify-between gap-6 rounded-[8px] border border-[#010BBF] px-6 py-5 text-left"
            aria-expanded="false"
            data-index={i}
          >
            <span class="font-poppins text-sm font-normal">{faq.question}</span>
            <Polygon class="faq-icon flex-shrink-0 w-8 h-7 transition-transform duration-300" />
          </button>
          <div class="faq-answer hidden px-1 pt-3">
            <p class="font-poppins text-sm leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>

    <script>
      document.querySelectorAll('.faq-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item') as HTMLElement;
          const answer = item.querySelector('.faq-answer') as HTMLElement;
          const icon = btn.querySelector('.faq-icon') as HTMLElement;
          const isOpen = btn.getAttribute('aria-expanded') === 'true';

          btn.setAttribute('aria-expanded', String(!isOpen));
          answer.classList.toggle('hidden', isOpen);
          icon.style.transform = isOpen ? '' : 'rotate(180deg)';
        });
      });
    </script>

    <div class="mb-5"></div>

    </Layout>