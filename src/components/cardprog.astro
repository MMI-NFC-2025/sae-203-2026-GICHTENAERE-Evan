---
const { nom, heure, scene, type, imageUrl } = Astro.props;
---

<div class="flex items-center gap-4 rounded-[15px] border border-gray-200 bg-white p-4 shadow-sm">
  <!-- Photo artiste ronde -->
  <div class="flex-shrink-0">
    <img
      src={imageUrl}
      alt={nom}
      class="w-20 h-20 rounded-full object-cover border-2 border-[#058CD8]"
    />
  </div>

  <!-- Infos artiste -->
  <div class="flex flex-col">
    <h3 class="text-lg font-bold font-inder">{nom}</h3>
    <span class="text-sm font-[Poppins,sans-serif] text-gray-600">{heure}</span>
    <span class="text-sm font-[Poppins,sans-serif] text-gray-500">{scene}</span>
    <span class="text-sm font-bold font-[Poppins,sans-serif] text-gray-800">{type}</span>
  </div>
</div>
