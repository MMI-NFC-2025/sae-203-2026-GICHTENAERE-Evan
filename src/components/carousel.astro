---
import CardMain from './card-main.astro';
import ArrowLeft from '../assets/Button_arr_left.svg';
import ArrowRight from '../assets/Button_arr_right.svg';

const { artistes } = Astro.props;
const pbUrl = 'https://sae203.lesrivesduterritoire.evangichtenaere.fr:443';
---

<section class="py-8 px-6">
  <h2 class="text-2xl font-normal font-inder mb-6">Artistes présents au festival</h2>

  <div class="relative">
    <!-- Conteneur scrollable -->
    <div
      id="carousel-track"
      class="flex gap-6 overflow-x-auto scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    >
      {artistes.map((artiste: any) => (
        <CardMain
          nom={artiste.nom_artiste}
          description={artiste.description_artiste}
          imageUrl={`${pbUrl}/api/files/artiste/${artiste.id}/${artiste.photo_artiste}`}
        />
      ))}
    </div>

    <!-- Boutons de navigation -->
    <div class="flex justify-center gap-6 mt-6">
      <button id="carousel-prev" aria-label="Précédent" class="transition-transform duration-200 hover:scale-105">
        <ArrowLeft class="w-12 h-12" />
      </button>
      <button id="carousel-next" aria-label="Suivant" class="transition-transform duration-200 hover:scale-105">
        <ArrowRight class="w-12 h-12" />
      </button>
    </div>
  </div>
</section>

<script>
  const track = document.querySelector('#carousel-track') as HTMLElement;
  const prevBtn = document.querySelector('#carousel-prev');
  const nextBtn = document.querySelector('#carousel-next');

  const scrollAmount = 300;

  prevBtn?.addEventListener('click', () => {
    track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });

  nextBtn?.addEventListener('click', () => {
    track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });

  // Drag to scroll (souris)
  let isDown = false;
  let startX = 0;
  let scrollLeft = 0;

  track.addEventListener('mousedown', (e) => {
    isDown = true;
    track.style.cursor = 'grabbing';
    startX = e.pageX - track.offsetLeft;
    scrollLeft = track.scrollLeft;
  });

  track.addEventListener('mouseleave', () => {
    isDown = false;
    track.style.cursor = 'grab';
  });

  track.addEventListener('mouseup', () => {
    isDown = false;
    track.style.cursor = 'grab';
  });

  track.addEventListener('mousemove', (e) => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - track.offsetLeft;
    track.scrollLeft = scrollLeft - (x - startX);
  });

  track.style.cursor = 'grab';
</script>
