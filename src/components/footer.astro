---
import Logo from '../assets/icon/svg_logo_les_rives_territoire.svg';
import Line from '../assets/Line_footer.svg';
import Instagram from '../assets/instagram_footer.svg';
import TikTok from '../assets/Tikokt_logo-footer.svg';
import X from '../assets/X_footer-logo.svg';
import LinkedIn from '../assets/Linkdin-footer.svg';
---

<footer class="w-full bg-[#058CD8] flex flex-col items-center py-8 gap-6">

  <!-- Logo centré -->
  <Logo class="w-24 h-24" />

  <!-- Ligne séparatrice -->
  <Line class="w-full max-w-sm" />

  <!-- Icônes réseaux sociaux -->
  <div class="flex items-center gap-6">
    <a href="https://www.tiktok.com" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
      <TikTok class="w-10 h-10" />
    </a>
    <a href="https://www.instagram.com" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
      <Instagram class="w-10 h-10" />
    </a>
    <a href="https://www.x.com" aria-label="X" target="_blank" rel="noopener noreferrer">
      <X class="w-10 h-10" />
    </a>
    <a href="https://www.linkedin.com" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
      <LinkedIn class="w-10 h-10" />
    </a>
  </div>

  <!-- Ligne séparatrice -->
  <Line class="w-full max-w-sm" />

  <!-- Contact -->
  <div class="flex flex-col gap-2 text-white text-sm w-full">
    <p class="text-center font-semibold tracking-widest uppercase">Contact</p>
    <p class="pl-[34.5px]">+33 X XX XX XX XX</p>
    <p class="pl-[34.5px]">nathan.batista_balanche@edu.univ-fcomte.fr</p>
  </div>

</footer>
